# Core Adobe Commerce / Magento GraphQL (required for real Adobe mode)
VITE_ADOBE_COMMERCE_GRAPHQL_URL=https://www.aemshop.net/graphql
VITE_ADOBE_STORE_VIEW_CODE=default
VITE_ADOBE_CURRENCY=USD

# Catalog source: core or catalog-service
VITE_ADOBE_CATALOG_MODE=catalog-service
VITE_ADOBE_CATALOG_GRAPHQL_URL=https://www.aemshop.net/cs-graphql
# Optional PLP seed list. When empty, the app gets page SKUs from Core GraphQL.
VITE_ADOBE_CATALOG_SKUS=

# Catalog Service context
VITE_ADOBE_ENVIRONMENT_ID=f38a0de0-764b-41fa-bd2c-5bc2f3c7b39a
VITE_ADOBE_WEBSITE_CODE=base
VITE_ADOBE_STORE_CODE=main_website_store
VITE_ADOBE_CUSTOMER_GROUP=NOT LOGGED IN
VITE_ADOBE_API_KEY=4dfa19c9fe6f4cccade55cc5b3da94f7
SITE_URL=https://your-production-domain.example
