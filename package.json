{
  "name": "aem-eds-vite-boilerplate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "An AEM Edge Delivery Services boilerplate powered by Vite, Preact, and TypeScript.",
  "scripts": {
    "dev": "node scripts/dev-aem.mjs",
    "dev:aem:build": "vite build --config vite.aem.config.ts --watch",
    "build:aem": "vite build --config vite.aem.config.ts",
    "build": "tsc -b && npm run build:aem"
  },
  "dependencies": {
    "preact": "^10.29.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^24.13.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-compression2": "^2.5.3"
  }
}
